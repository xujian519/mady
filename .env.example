# ============================================================
# Mady 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================================

# ========== LLM Provider（至少配置一组） ==========
# 支持的 Provider: deepseek, zhipu, kimi, generic
# DeepSeek 推荐模型: deepseek-v4-flash（默认）, deepseek-v4-pro（增强）
# 智谱 GLM 推荐模型: glm-5.2（coding）, glm-5v-turbo（多模态）
# Kimi 推荐模型: kimi-k2.6（多模态）, kimi-k2.7-code（coding 专属）
MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=
# Kimi Code coding 专属端点（使用独立额度，二者选一）
KIMI_CODE_API_KEY=
KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
AGENT_MODEL=deepseek-v4-flash
EXECUTION_MODE=serial              # serial | parallel

# ========== Thinking / Reasoning ==========
THINKING_EFFORT=medium             # none | low | medium | high
THINKING_BUDGET=8000               # max tokens for thinking
THINKING_DISPLAY=expanded          # collapsed | expanded
THINKING_INCLUDE_THOUGHTS=false

# ========== Mady 应用数据目录 ==========
# MADY_HOME 是 mady 存储运行时数据的根目录（workspace/sessions/manifests）。
# 默认 ~/.mady。设为绝对路径可自定义。manifest 已通过 go:embed 内置，
# 放在 $MADY_HOME/manifests/ 的同名 JSON 会覆盖内置版本（无需重编译）。
MADY_HOME=
# manifest 外部覆盖目录（默认 $MADY_HOME/manifests，留空走默认）
MANIFEST_DIR=
# workspace 目录（默认 $MADY_HOME/workspace）
WORKSPACE_DIR=
# session 持久化目录，仅 mady serve 使用（默认 $MADY_HOME/sessions）
SESSION_DIR=

# ========== Server ==========
PORT=8080

# ========== Web Search ==========
WEB_SEARCH_PROVIDER=brave          # brave | tavily | serpapi | searxng
WEB_SEARCH_API_KEY=
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_COUNTRY=CN
TAVILY_API_KEY=
SERPAPI_API_KEY=
SERPAPI_LOCATION=
SEARXNG_URL=

# ========== Browser / Computer Use ==========
AGENT_BROWSER_ENABLED=false
AGENT_BROWSER_PATH=
BROWSER_PATH=
CHROME_PATH=
BROWSER_USER_AGENT=
BROWSER_PROXY_URL=
BROWSER_ACCEPT_LANGUAGE=

# Camofox (cloud browser)
CAMOFOX_URL=
CAMOFOX_USER_ID=
CAMOFOX_SESSION_KEY=
CAMOFOX_ADOPT_EXISTING_TAB=false

# Browserbase
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_SESSION_TIMEOUT=

# Firecrawl
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
FIRECRAWL_BROWSER_TTL=

# Browser Use
BROWSER_USE_API_KEY=

# Computer Use (macOS)
COMPUTER_USE_APPROVAL=auto         # auto | manual
WAYLAND_DISPLAY=

# ========== Knowledge / Wiki ==========
# WIKI_PATH 是 wiki 知识库目录（SQLite backend 不可用时的回退）
WIKI_PATH=

# ========== 向量检索（oMLX 本地嵌入服务） ==========
# 配置 OMLX_API_KEY 后自动启用 SQLite 向量检索（FTS + Vector RRF 融合）
# 需预先在 KNOWLEDGE_DB_DIR 放置 knowledge.db
OMLX_BASE_URL=http://127.0.0.1:8000/v1
OMLX_API_KEY=
OMLX_EMBED_MODEL=bge-m3-mlx-8bit
OMLX_RERANK_MODEL=Qwen3-Reranker-4B-4bit-MLX
KNOWLEDGE_DB_DIR=
# 设为 on 启用 cross-encoder 重排（RRF 融合后对 Top-20 重排精选 Top-5）
KNOWLEDGE_RERANK=off
# 用户可写库路径（add_document 工具写入，三路 RRF 融合参与检索）
# 默认 $MADY_HOME/knowledge/user.db
USER_DB_PATH=

# ========== Skills ==========
# 注意：mady tui 当前不加载技能，SKILL_DIRS 仅 example/cli-chat 使用
SKILL_DIRS=
AGENT_SKILLS=                      # comma-separated skill names

# ========== TUI / Terminal ==========
TUI_THEME=auto                     # auto | light | dark | <theme-name>
TUI_COLORMODE=auto                 # auto | truecolor | 256 | 16
AGENT_TUI_THEME=
NO_COLOR=false
FORCE_COLOR=false

# ========== Vision / Gemini Search ==========
GEMINI_SEARCH_MODEL=gemini-2.0-flash

# ========== Misc ==========
API_KEY=                           # fallback/legacy generic API key
BASE_URL=                          # generic OpenAI-compatible base URL

# ============================================================
# Mady 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================================

# ========== LLM Provider（至少配置一组） ==========
# 支持的 Provider: anthropic, openai, gemini, deepseek, zhipu, kimi, qwen
MODEL=claude-sonnet-4-20250601
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=
QWEN_API_KEY=
AGENT_MODEL=claude-sonnet-4-20250601
EXECUTION_MODE=serial              # serial | parallel

# ========== Thinking / Reasoning ==========
THINKING_EFFORT=medium             # none | low | medium | high
THINKING_BUDGET=8000               # max tokens for thinking
THINKING_DISPLAY=expanded          # collapsed | expanded
THINKING_INCLUDE_THOUGHTS=false

# ========== Server ==========
PORT=8080
STORE_DIR=./data/store

# ========== Web Search ==========
WEB_SEARCH_PROVIDER=brave          # brave | tavily | serpapi | searxng
WEB_SEARCH_API_KEY=
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_COUNTRY=CN
TAVILY_API_KEY=
SERPAPI_API_KEY=
SERPAPI_LOCATION=
SEARXNG_URL=

# ========== Browser / Computer Use ==========
AGENT_BROWSER_ENABLED=false
AGENT_BROWSER_PATH=
BROWSER_PATH=
CHROME_PATH=
BROWSER_USER_AGENT=
BROWSER_PROXY_URL=
BROWSER_ACCEPT_LANGUAGE=

# Camofox (cloud browser)
CAMOFOX_URL=
CAMOFOX_USER_ID=
CAMOFOX_SESSION_KEY=
CAMOFOX_ADOPT_EXISTING_TAB=false

# Browserbase
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_SESSION_TIMEOUT=

# Firecrawl
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
FIRECRAWL_BROWSER_TTL=

# Browser Use
BROWSER_USE_API_KEY=

# Computer Use (macOS)
COMPUTER_USE_APPROVAL=auto         # auto | manual
WAYLAND_DISPLAY=

# ========== Knowledge / Wiki ==========
WIKI_PATH=
KNOWLEDGE_DIR=

# ========== Skills ==========
SKILL_DIR=./skills
AGENT_SKILLS=                      # comma-separated skill names

# ========== TUI / Terminal ==========
TUI_THEME=auto                     # auto | light | dark | <theme-name>
TUI_COLORMODE=auto                 # auto | truecolor | 256 | 16
AGENT_TUI_THEME=
NO_COLOR=false
FORCE_COLOR=false

# ========== Vision / Gemini Search ==========
GEMINI_SEARCH_MODEL=gemini-2.0-flash

# ========== Misc ==========
API_KEY=                           # fallback/legacy generic API key
BASE_URL=                          # generic OpenAI-compatible base URL
